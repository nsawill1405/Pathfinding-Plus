{
  "name": "PathfindingPlus",
  "emitLegacyScripts": false,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Packages": {
        "$className": "Folder",
        "PathfindingPlus": {
          "$path": "src"
        }
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "PathfindingPlusExample": {
        "$path": "example/src/ServerScriptService"
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Position": [0, -10, 0],
          "Size": [512, 20, 512]
        }
      }
    }
  }
}
